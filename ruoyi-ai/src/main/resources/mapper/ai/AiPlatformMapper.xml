<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.ai.mapper.AiPlatformMapper">
    
    <resultMap type="com.ruoyi.ai.domain.AiPlatform" id="AiPlatformResult">
        <id     property="platformId"    column="platform_id"    />
        <result property="platformName"  column="platform_name"  />
        <result property="platformCode"  column="platform_code"  />
        <result property="apiUrl"        column="api_url"        />
        <result property="apiKey"        column="api_key"        />
        <result property="defaultModel"  column="default_model"  />
        <result property="status"        column="status"         />
        <result property="createBy"      column="create_by"      />
        <result property="createTime"    column="create_time"    />
        <result property="updateBy"      column="update_by"      />
        <result property="updateTime"    column="update_time"    />
        <result property="remark"        column="remark"         />
    </resultMap>
    
    <sql id="selectAiPlatformVo">
        select platform_id, platform_name, platform_code, api_url, api_key, default_model, status, create_by, create_time, update_by, update_time, remark 
        from ai_platform
    </sql>
    
    <select id="selectAiPlatformById" parameterType="Long" resultMap="AiPlatformResult">
        <include refid="selectAiPlatformVo"/>
        where platform_id = #{platformId}
    </select>
    
    <select id="selectAiPlatformByCode" parameterType="String" resultMap="AiPlatformResult">
        <include refid="selectAiPlatformVo"/>
        where platform_code = #{platformCode}
    </select>
    
    <select id="selectAiPlatformList" parameterType="com.ruoyi.ai.domain.AiPlatform" resultMap="AiPlatformResult">
        <include refid="selectAiPlatformVo"/>
        <where>
            <if test="platformName != null and platformName != ''">
                AND platform_name like '%'||#{platformName}||'%'
            </if>
            <if test="platformCode != null and platformCode != ''">
                AND platform_code = #{platformCode}
            </if>
            <if test="status != null and status != ''">
                AND status = #{status}
            </if>
        </where>
    </select>
    
    <insert id="insertAiPlatform" parameterType="com.ruoyi.ai.domain.AiPlatform" useGeneratedKeys="true" keyProperty="platformId">
        insert into ai_platform
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="platformName != null and platformName != ''">platform_name,</if>
            <if test="platformCode != null and platformCode != ''">platform_code,</if>
            <if test="apiUrl != null and apiUrl != ''">api_url,</if>
            <if test="apiKey != null">api_key,</if>
            <if test="defaultModel != null">default_model,</if>
            <if test="status != null">status,</if>
            <if test="createBy != null">create_by,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateBy != null">update_by,</if>
            <if test="updateTime != null">update_time,</if>
            <if test="remark != null">remark,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="platformName != null and platformName != ''">#{platformName},</if>
            <if test="platformCode != null and platformCode != ''">#{platformCode},</if>
            <if test="apiUrl != null and apiUrl != ''">#{apiUrl},</if>
            <if test="apiKey != null">#{apiKey},</if>
            <if test="defaultModel != null">#{defaultModel},</if>
            <if test="status != null">#{status},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateBy != null">#{updateBy},</if>
            <if test="updateTime != null">#{updateTime},</if>
            <if test="remark != null">#{remark},</if>
        </trim>
    </insert>
    
    <update id="updateAiPlatform" parameterType="com.ruoyi.ai.domain.AiPlatform">
        update ai_platform
        <trim prefix="SET" suffixOverrides=",">
            <if test="platformName != null and platformName != ''">platform_name = #{platformName},</if>
            <if test="platformCode != null and platformCode != ''">platform_code = #{platformCode},</if>
            <if test="apiUrl != null and apiUrl != ''">api_url = #{apiUrl},</if>
            <if test="apiKey != null">api_key = #{apiKey},</if>
            <if test="defaultModel != null">default_model = #{defaultModel},</if>
            <if test="status != null">status = #{status},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
            <if test="remark != null">remark = #{remark},</if>
        </trim>
        where platform_id = #{platformId}
    </update>
    
    <delete id="deleteAiPlatformById" parameterType="Long">
        delete from ai_platform where platform_id = #{platformId}
    </delete>
    
    <delete id="deleteAiPlatformByIds" parameterType="String">
        delete from ai_platform where platform_id in 
        <foreach item="platformId" collection="array" open="(" separator="," close=")">
            #{platformId}
        </foreach>
    </delete>
    
</mapper>
